<?php
declare(strict_types=1);
require_once __DIR__ . '/inventory-helpers.php';
ensureSessionStarted();
try {
    $staff = requireStaffLogin();
    if (!meetingCanAccessStaffModule($staff, 'inventory')) { showErrorPage('دسترسی شما به انبارگردانی فعال نیست.'); }
    $canEdit = inventoryCanEditFull($staff) && !meetingIsViewOnly($staff);
    if ($_SERVER['REQUEST_METHOD'] === 'POST') {
        checkCsrf();
        if (!$canEdit) { flash('نقش شما اجازه ثبت شمارش ندارد.', 'bad'); redirect('staff-inventory-counting.php'); }
        $itemName = trim((string)($_POST['item_name'] ?? ''));
        if ($itemName === '') { flash('نام کالا الزامی است.', 'bad'); redirect('staff-inventory-counting.php'); }
        getPdo()->prepare('INSERT INTO inventory_movements_staging (movement_type, item_name, technical_code, oem_code, internal_code, quantity, unit_name, source_location, movement_note, created_by_staff_id, sync_status, created_at) VALUES ("COUNT", ?, ?, ?, ?, ?, ?, ?, ?, ?, "Pending", NOW())')->execute([$itemName, trim((string)($_POST['technical_code'] ?? '')), trim((string)($_POST['oem_code'] ?? '')), trim((string)($_POST['internal_code'] ?? '')), meetingDecimalOrNull((string)($_POST['counted_quantity'] ?? '')) ?: '0', trim((string)($_POST['unit_name'] ?? 'عدد')), trim((string)($_POST['location'] ?? '')), trim((string)($_POST['movement_note'] ?? '')), (int)($staff['id'] ?? 0)]);
        flash('شمارش کالا ثبت شد.'); redirect('staff-inventory-counting.php');
    }
    renderHeader('انبارگردانی', 'StockCenter Counting'); inventoryHeaderActions('counting');
?>
<main class="auth-wrap wide-auth inventory-page"><form class="card form-card" method="post" action="staff-inventory-counting.php"><?= csrfField() ?><div class="form-grid"><h3 class="form-section-title wide">ثبت شمارش دوره‌ای</h3><label>نام کالا *<input name="item_name" required <?= $canEdit ? '' : 'disabled' ?>></label><label>کد فنی<input class="input-number" name="technical_code" <?= $canEdit ? '' : 'disabled' ?>></label><label>OEM<input class="input-number" name="oem_code" <?= $canEdit ? '' : 'disabled' ?>></label><label>کد داخلی<input class="input-number" name="internal_code" <?= $canEdit ? '' : 'disabled' ?>></label><label>مقدار شمارش‌شده<input class="stock-field input-number" name="counted_quantity" type="number" step="0.01" min="0" required <?= $canEdit ? '' : 'disabled' ?>></label><label>واحد<select name="unit_name" <?= $canEdit ? '' : 'disabled' ?>><?php foreach (inventoryUnits() as $v): ?><option><?= e($v) ?></option><?php endforeach; ?></select></label><label>لوکیشن<input name="location" <?= $canEdit ? '' : 'disabled' ?>></label><label class="wide">توضیحات<textarea name="movement_note" <?= $canEdit ? '' : 'disabled' ?>></textarea></label></div><div class="action-row"><button class="btn primary" <?= $canEdit ? '' : 'disabled' ?>>ثبت شمارش</button><a class="btn ghost" href="staff-inventory.php">بازگشت</a></div></form></main>
<?php renderFooter(); } catch (Throwable $e) { showErrorPage('خطا در انبارگردانی.', $e->getMessage()); }
